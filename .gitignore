# ========================
# Complementary Fashions
# Root .gitignore
# ========================

# Dependencies
node_modules/
.pnp
.pnp.js

# Environment files - NEVER commit these
.env
.env.local
.env.development
.env.production
.env.staging
*.env

# Build outputs
dist/
build/
out/

# Uploads (user-uploaded files)
/uploads/
backend/uploads/

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
lerna-debug.log*

# OS files
.DS_Store
.DS_Store?
._*
.Spotlight-V7
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# IDE / Editor
.idea/
.vscode/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
*.swp

# Docker
docker-compose.override.yml

# Misc
*.pem
.eslintcache
