# ========================
# Server
# ========================
PORT=3000
NODE_ENV=development

# ========================
# Database (PostgreSQL)
# ========================
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_USERNAME=cf_user
DATABASE_PASSWORD=cf_secure_password
DATABASE_NAME=complementary_fashions

# ========================
# JWT Auth
# ========================
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=generate_a_random_secret_here
JWT_EXPIRES_IN=7d
ADMIN_JWT_SECRET=generate_a_different_random_secret_here

# ========================
# CORS
# ========================
CORS_ORIGINS=http://localhost:4200,http://localhost:4201

# ========================
# File Uploads
# ========================
UPLOAD_DEST=./uploads

# ========================
# Frontend URLs
# ========================
FRONTEND_URL=http://localhost:4200
ADMIN_URL=http://localhost:4201

# ========================
# Mail (Nodemailer)
# ========================
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USER=your@gmail.com
MAIL_PASS=your_gmail_app_password
MAIL_FROM=noreply@complementaryfashions.com

# ========================
# M-Pesa (Safaricom Daraja)
# ========================
# Register at https://developer.safaricom.co.ke
PAYBILL_SHORT_CODE=
PAYBILL_PASS_KEY=
PAYBILL_CONSUMER_KEY=
PAYBILL_CONSUMER_SECRET=
PAYBILL_CALLBACK_URL=https://yourdomain.com/api/payments/mpesa/callback
